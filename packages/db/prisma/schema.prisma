generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum LeadStatus {
  frio
  consulta
  interesado
  caliente
  listo_para_cobrar
  vendido
  cerrado

  @@map("lead_status")
}

enum MessageDirection {
  incoming
  outgoing

  @@map("message_direction")
}

enum UserRole {
  admin
  vendedor
  viewer

  @@map("user_role")
}

enum StockMovementType {
  sync
  reserve
  release
  commit
  manual_adjust

  @@map("stock_movement_type")
}

enum ScoreEventSource {
  rule
  llm
  manual
  import

  @@map("score_event_source")
}

enum FeedbackTargetType {
  message
  llm_trace
  lead
  conversation
  bot_response_event

  @@map("feedback_target_type")
}

enum EvalSplit {
  train
  val
  test
  holdout

  @@map("eval_split")
}

enum PaymentProvider {
  mercadopago

  @@map("payment_provider")
}

enum PaymentIntegrationStatus {
  disconnected
  connected
  expired
  error

  @@map("payment_integration_status")
}

enum PaymentAttemptStatus {
  draft
  link_generated
  pending
  approved
  rejected
  cancelled
  expired
  error

  @@map("payment_attempt_status")
}

/**
 * Ciclo de vida de las ventas iniciadas desde la tienda pública.
 */
enum OrderStatus {
  pending_payment
  paid
  failed
  cancelled
  expired
  fulfilled
  refunded

  @@map("order_status")
}

model Tenant {
  id                     String                     @id @default(uuid()) @db.Uuid
  name                   String
  /**
   * Slug único para catálogo público `/tienda/[slug]`.
   */
  publicCatalogSlug      String?                    @unique @map("public_catalog_slug")
  /**
   * Origen público del storefront del tenant (sin barra final). Si está seteado,
   * se usa para armar las `back_urls` de Mercado Pago al iniciar el checkout
   * (en vez de `PUBLIC_STOREFRONT_BASE_URL`). Necesario cuando cada cliente vive
   * en su propio dominio (cliente1.com, cliente2.com, ...).
   */
  storefrontBaseUrl      String?                    @map("storefront_base_url")
  whatsappNumber         String                     @map("whatsapp_number")
  plan                   String                     @default("starter")
  senderRateMs           Int                        @default(500) @map("sender_rate_ms")
  senderPauseEvery       Int                        @default(20) @map("sender_pause_every")
  senderPauseMs          Int                        @default(2500) @map("sender_pause_ms")
  llmAssistEnabled       Boolean                    @default(false) @map("llm_assist_enabled")
  llmConfidenceThreshold Float                      @default(0.72) @map("llm_confidence_threshold")
  llmGuardrailsStrict    Boolean                    @default(true) @map("llm_guardrails_strict")
  llmRolloutPercent      Int                        @default(0) @map("llm_rollout_percent")
  llmModelName           String                     @default("self-hosted-default") @map("llm_model_name")
  createdAt              DateTime                   @default(now()) @map("created_at")
  updatedAt              DateTime                   @updatedAt @map("updated_at")
  products               Product[]
  productVariants        ProductVariant[]
  leads                  Lead[]
  conversations          Conversation[]
  messages               Message[]
  users                  AppUser[]
  stockMovements         StockMovement[]
  botPlaybooks           BotPlaybook[]
  botResponseEvents      BotResponseEvent[]
  conversationMemory     ConversationMemory[]
  llmTraces              LlmTrace[]
  leadScoreEvents        LeadScoreEvent[]
  humanFeedback          HumanFeedback[]
  evalDatasetItems       EvalDatasetItem[]
  paymentIntegrations    TenantPaymentIntegration[]
  paymentAttempts        PaymentAttempt[]
  orders                 Order[]
  tenantKnowledge        TenantKnowledge?
  storeConfig            TenantStoreConfig?
  categories             Category[]
  conversationSuggestions ConversationSuggestion[]
  suggestionOutcomes      SuggestionOutcome[]
  styleProfile            TenantStyleProfile?
  conversationTurnExamples ConversationTurnExample[]

  @@map("tenants")
}

/**
 * Configuración visual de la tienda pública por tenant.
 */
model TenantStoreConfig {
  tenantId  String   @id @map("tenant_id") @db.Uuid
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_store_configs")
}

/**
 * Contexto de negocio por tenant (ops / RAG). Tabla usada también con SQL raw.
 */
model TenantKnowledge {
  tenantId         String   @id @map("tenant_id") @db.Uuid
  businessCategory String   @default("general") @map("business_category")
  businessLabels   String[] @default([]) @map("business_labels")
  profile          Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_knowledge")
}

model BotPlaybook {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  intent    String
  variant   String
  template  String
  weight    Int      @default(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, intent, variant])
  @@index([tenantId, intent, isActive])
  @@map("bot_playbooks")
}

model BotResponseEvent {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  leadId    String?  @map("lead_id") @db.Uuid
  phone     String
  intent    String
  variant   String
  message   String
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, intent, variant, createdAt])
  @@index([tenantId, leadId, createdAt])
  @@map("bot_response_events")
}

model AppUser {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  email         String
  passwordHash  String          @map("password_hash")
  role          UserRole        @default(viewer)
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  humanFeedback HumanFeedback[]

  @@unique([email])
  @@index([tenantId, role, isActive])
  @@map("app_users")
}

model Product {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  name              String
  price             Decimal           @db.Decimal(10, 2)
  imageUrl          String?           @map("image_url")
  imageUrls         String[]          @default([]) @map("image_urls")
  tags              String[]
  /// Algunas BD legacy tienen stock a nivel producto; el stock operativo está en `product_variants`.
  stock             Int?              @default(0) @map("stock")
  reservedStock     Int?              @default(0) @map("reserved_stock")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variants          ProductVariant[]
  stockMovements    StockMovement[]
  productCategories ProductCategory[]

  @@unique([tenantId, name])
  @@map("products")
}

/**
 * Categoría de catálogo por tenant (árbol vía `parentId`).
 */
model Category {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  name      String
  slug      String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent            Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children          Category[]        @relation("CategoryHierarchy")
  productCategories ProductCategory[]
  variantCategories VariantCategory[]

  @@unique([tenantId, slug])
  @@index([tenantId, parentId])
  @@index([tenantId, isActive])
  @@map("categories")
}

model ProductCategory {
  productId  String   @map("product_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@map("product_categories")
}

model VariantCategory {
  variantId  String         @map("variant_id") @db.Uuid
  categoryId String         @map("category_id") @db.Uuid
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  category   Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([variantId, categoryId])
  @@index([categoryId])
  @@map("variant_categories")
}

model ProductVariant {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  productId         String            @map("product_id") @db.Uuid
  sku               String
  attributes        Json
  /// Copia indexada de `attributes` (talle / talla) para filtros SQL.
  variantTalle      String?           @map("variant_talle") @db.VarChar(160)
  /// Copia indexada de `attributes.color`.
  variantColor      String?           @map("variant_color") @db.VarChar(160)
  /// Marca o línea/modelo (`marca` o `modelo` en JSON).
  variantMarca      String?           @map("variant_marca") @db.VarChar(200)
  price             Decimal?          @db.Decimal(10, 2)
  stock             Int               @default(0)
  reservedStock     Int               @default(0) @map("reserved_stock")
  isActive          Boolean           @default(true) @map("is_active")
  imageUrls         String[]          @default([]) @map("image_urls")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockMovements    StockMovement[]
  variantCategories VariantCategory[]
  orderItems        OrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId, productId, isActive])
  @@index([tenantId, updatedAt])
  @@index([tenantId, variantTalle])
  @@index([tenantId, variantColor])
  @@index([tenantId, variantMarca])
  @@map("product_variants")
}

model Lead {
  id                       String               @id @default(uuid()) @db.Uuid
  tenantId                 String               @map("tenant_id") @db.Uuid
  phone                    String
  customerName             String?              @map("customer_name")
  product                  String?
  productVariantId         String?              @map("product_variant_id") @db.Uuid
  productVariantAttributes Json?                @map("product_variant_attributes")
  status                   LeadStatus           @default(frio)
  score                    Int                  @default(0)
  hasStockReservation      Boolean              @default(false) @map("has_stock_reservation")
  reservationExpiresAt     DateTime?            @map("reservation_expires_at")
  profilePictureUrl        String?              @map("profile_picture_url")
  lastMessage              String?              @map("last_message")
  /**
   * Si está seteado, el lead no se lista en Clientes ni Conversaciones (borrado suave de bandeja).
   */
  inboxHiddenAt            DateTime?            @map("inbox_hidden_at")
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @updatedAt @map("updated_at")
  tenant                   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation             Conversation?
  memory                   ConversationMemory[]
  llmTraces                LlmTrace[]
  scoreEvents              LeadScoreEvent[]
  paymentAttempts          PaymentAttempt[]

  @@index([tenantId, status, score])
  @@index([tenantId, phone])
  @@map("leads")
}

model StockMovement {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @map("tenant_id") @db.Uuid
  productId     String?           @map("product_id") @db.Uuid
  variantId     String?           @map("variant_id") @db.Uuid
  movementType  StockMovementType @map("movement_type")
  deltaStock    Int               @default(0) @map("delta_stock")
  deltaReserved Int               @default(0) @map("delta_reserved")
  reason        String?
  source        String?
  leadId        String?           @map("lead_id") @db.Uuid
  orderId       String?           @map("order_id") @db.Uuid
  phone         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant       ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  order         Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([tenantId, variantId, createdAt])
  @@index([tenantId, productId, createdAt])
  @@index([tenantId, movementType, createdAt])
  @@index([tenantId, orderId, createdAt])
  @@map("stock_movements")
}

model Conversation {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  phone           String
  leadId          String?              @unique @map("lead_id")
  lastMessage     String?              @map("last_message")
  state           String               @default("open")
  archivedAt      DateTime?            @map("archived_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead            Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  memory             ConversationMemory[]
  llmTraces          LlmTrace[]
  paymentAttempts    PaymentAttempt[]
  suggestions        ConversationSuggestion[]
  suggestionOutcomes SuggestionOutcome[]

  @@index([tenantId, phone])
  @@map("conversations")
}

model ConversationSuggestion {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  conversationId      String    @map("conversation_id") @db.Uuid
  triggerMessageId    String?   @map("trigger_message_id") @db.Uuid
  trigger             String
  intent              String?
  leadScore           Int?      @map("lead_score")
  leadStatus          String?   @map("lead_status")
  reasoning           Json?
  recommendedVariants Json?     @map("recommended_variants")
  draftReply          String?   @map("draft_reply")
  summaryForSeller    String?   @map("summary_for_seller")
  status              String    @default("fresh")
  generatedAt         DateTime  @default(now()) @map("generated_at")
  usedAt              DateTime? @map("used_at")
  llmModel            String?   @map("llm_model")
  llmLatencyMs        Int?      @map("llm_latency_ms")
  llmTokensIn         Int?      @map("llm_tokens_in")
  llmTokensOut        Int?      @map("llm_tokens_out")

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  outcomes     SuggestionOutcome[]

  @@index([conversationId, generatedAt(sort: Desc)])
  @@index([tenantId, status])
  @@map("conversation_suggestions")
}

model SuggestionOutcome {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  conversationId  String   @map("conversation_id") @db.Uuid
  suggestionId    String?  @map("suggestion_id") @db.Uuid
  draftReply      String?  @map("draft_reply")
  sentMessage     String   @map("sent_message")
  draftWasOffered Boolean  @default(false) @map("draft_was_offered")
  usedAsIs        Boolean  @default(false) @map("used_as_is")
  editDistance    Int      @default(0) @map("edit_distance")
  tokensAdded     Int      @default(0) @map("tokens_added")
  tokensRemoved   Int      @default(0) @map("tokens_removed")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  suggestion   ConversationSuggestion? @relation(fields: [suggestionId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([conversationId, createdAt(sort: Desc)])
  @@map("suggestion_outcomes")
}

model ConversationTurnExample {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  conversationId  String   @map("conversation_id") @db.Uuid
  incomingText    String   @map("incoming_text")
  outgoingText    String   @map("outgoing_text")
  productName     String?  @map("product_name")
  intentHint      String?  @map("intent_hint")
  leadStage       String?  @map("lead_stage")
  embeddingModel  String   @default("text-embedding-3-small") @map("embedding_model")
  source          String   @default("real")
  segment         String?
  scenario        String?
  indexedAt       DateTime @default(now()) @map("indexed_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, indexedAt(sort: Desc)])
  @@index([tenantId, source])
  @@index([conversationId])
  @@map("conversation_turn_examples")
}

model TenantStyleProfile {
  tenantId          String   @id @map("tenant_id") @db.Uuid
  avgLength         Int      @default(0) @map("avg_length")
  emojiDensity      Float    @default(0) @map("emoji_density")
  formality         String   @default("unknown")
  topGreetings      Json     @default("[]") @map("top_greetings")
  topClosings       Json     @default("[]") @map("top_closings")
  topEmojis         Json     @default("[]") @map("top_emojis")
  catchphrases      Json     @default("[]")
  usesAbbreviations Boolean  @default(false) @map("uses_abbreviations")
  sampleCount       Int      @default(0) @map("sample_count")
  computedAt        DateTime @default(now()) @map("computed_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_style_profiles")
}

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  phone             String
  message           String
  direction         MessageDirection
  externalMessageId String?          @map("external_message_id")
  correlationId     String?          @map("correlation_id")
  dedupeKey         String?          @map("dedupe_key")
  createdAt         DateTime         @default(now()) @map("created_at")
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  llmTraces         LlmTrace[]

  @@index([tenantId, phone, createdAt])
  @@index([tenantId, dedupeKey])
  @@map("messages")
}

model ConversationMemory {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  leadId         String        @unique @map("lead_id")
  conversationId String?       @unique @map("conversation_id")
  schemaVersion  Int           @default(1) @map("schema_version")
  facts          Json
  source         String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead           Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId, leadId])
  @@index([tenantId, updatedAt])
  @@map("conversation_memory")
}

model LlmTrace {
  id                 String           @id @default(uuid()) @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  leadId             String?          @map("lead_id") @db.Uuid
  conversationId     String?          @map("conversation_id") @db.Uuid
  messageId          String?          @map("message_id") @db.Uuid
  botResponseEventId String?          @map("bot_response_event_id") @db.Uuid
  correlationId      String?          @map("correlation_id")
  dedupeKey          String?          @map("dedupe_key")
  traceKind          String           @map("trace_kind")
  provider           String?
  model              String?
  request            Json
  response           Json
  promptTokens       Int?             @map("prompt_tokens")
  completionTokens   Int?             @map("completion_tokens")
  latencyMs          Int?             @map("latency_ms")
  handoffRequired    Boolean          @default(false) @map("handoff_required")
  error              String?
  createdAt          DateTime         @default(now()) @map("created_at")
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead               Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  conversation       Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message            Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)
  scoreEvents        LeadScoreEvent[]

  @@index([tenantId, createdAt])
  @@index([tenantId, leadId, createdAt])
  @@index([conversationId, createdAt])
  @@map("llm_traces")
}

model LeadScoreEvent {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  leadId         String           @map("lead_id") @db.Uuid
  previousScore  Int              @map("previous_score")
  newScore       Int              @map("new_score")
  delta          Int
  reason         String?
  source         ScoreEventSource @default(rule)
  metadata       Json?
  relatedTraceId String?          @map("related_trace_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead           Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  relatedTrace   LlmTrace?        @relation(fields: [relatedTraceId], references: [id], onDelete: SetNull)

  @@index([tenantId, leadId, createdAt])
  @@map("lead_score_events")
}

model HumanFeedback {
  id         String             @id @default(uuid()) @db.Uuid
  tenantId   String             @map("tenant_id") @db.Uuid
  targetType FeedbackTargetType @map("target_type")
  targetId   String             @map("target_id") @db.Uuid
  rating     Int?
  label      String?
  comment    String?
  appUserId  String?            @map("app_user_id") @db.Uuid
  createdAt  DateTime           @default(now()) @map("created_at")
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appUser    AppUser?           @relation(fields: [appUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, targetType, targetId])
  @@index([tenantId, createdAt])
  @@map("human_feedback")
}

model EvalDatasetItem {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String?   @map("tenant_id") @db.Uuid
  name      String
  slug      String?
  input     Json
  reference Json
  tags      String[]  @default([])
  split     EvalSplit @default(test)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, split, isActive])
  @@map("eval_dataset_items")
}

model TenantPaymentIntegration {
  id                    String                   @id @default(uuid()) @db.Uuid
  tenantId              String                   @map("tenant_id") @db.Uuid
  provider              PaymentProvider
  status                PaymentIntegrationStatus @default(disconnected)
  externalAccountId     String?                  @map("external_account_id")
  externalAccountLabel  String?                  @map("external_account_label")
  accessTokenEncrypted  String?                  @map("access_token_encrypted")
  refreshTokenEncrypted String?                  @map("refresh_token_encrypted")
  publicKey             String?                  @map("public_key")
  tokenType             String?                  @map("token_type")
  scope                 String?
  expiresAt             DateTime?                @map("expires_at")
  connectedAt           DateTime?                @map("connected_at")
  lastError             String?                  @map("last_error")
  metadata              Json?
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")
  tenant                Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentAttempts       PaymentAttempt[]

  @@unique([tenantId, provider])
  @@index([provider, externalAccountId])
  @@index([tenantId, status])
  @@map("tenant_payment_integrations")
}

model PaymentAttempt {
  id                   String                    @id @default(uuid()) @db.Uuid
  tenantId             String                    @map("tenant_id") @db.Uuid
  integrationId        String?                   @map("integration_id") @db.Uuid
  leadId               String?                   @map("lead_id") @db.Uuid
  conversationId       String?                   @map("conversation_id") @db.Uuid
  productVariantId     String?                   @map("product_variant_id") @db.Uuid
  orderId              String?                   @map("order_id") @db.Uuid
  provider             PaymentProvider
  status               PaymentAttemptStatus      @default(draft)
  amount               Decimal                   @db.Decimal(10, 2)
  currency             String                    @default("ARS")
  title                String
  externalReference    String                    @map("external_reference")
  externalPreferenceId String?                   @map("external_preference_id")
  externalPaymentId    String?                   @map("external_payment_id")
  checkoutUrl          String?                   @map("checkout_url")
  sandboxCheckoutUrl   String?                   @map("sandbox_checkout_url")
  paymentLinkSentAt    DateTime?                 @map("payment_link_sent_at")
  lastWebhookAt        DateTime?                 @map("last_webhook_at")
  paidAt               DateTime?                 @map("paid_at")
  expiresAt            DateTime?                 @map("expires_at")
  metadata             Json?
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  tenant               Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integration          TenantPaymentIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  lead                 Lead?                     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  conversation         Conversation?             @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  order                Order?                    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([provider, externalReference])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, leadId, createdAt])
  @@index([tenantId, orderId, createdAt])
  @@index([provider, externalPreferenceId])
  @@index([provider, externalPaymentId])
  @@map("payment_attempts")
}

/**
 * Venta originada en la tienda pública. Snapshot de items y comprador para trazabilidad.
 */
model Order {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  status            OrderStatus      @default(pending_payment)
  totalAmount       Decimal          @map("total_amount") @db.Decimal(10, 2)
  currency          String           @default("ARS")
  buyerName         String           @map("buyer_name")
  buyerEmail        String           @map("buyer_email")
  buyerPhone        String           @map("buyer_phone")
  buyerNotes        String?          @map("buyer_notes")
  externalReference String           @unique @map("external_reference")
  expiresAt         DateTime?        @map("expires_at")
  paidAt            DateTime?        @map("paid_at")
  fulfilledAt       DateTime?        @map("fulfilled_at")
  metadata          Json?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items             OrderItem[]
  paymentAttempts   PaymentAttempt[]
  stockMovements    StockMovement[]

  @@index([tenantId, status, createdAt])
  @@index([tenantId, createdAt])
  @@map("orders")
}

/**
 * Línea de Order. Mantiene snapshot del producto/variante al momento de la compra.
 */
model OrderItem {
  id                String         @id @default(uuid()) @db.Uuid
  orderId           String         @map("order_id") @db.Uuid
  productVariantId  String         @map("product_variant_id") @db.Uuid
  productName       String         @map("product_name")
  variantSku        String         @map("variant_sku")
  variantAttributes Json?          @map("variant_attributes")
  quantity          Int
  unitPrice         Decimal        @map("unit_price") @db.Decimal(10, 2)
  lineTotal         Decimal        @map("line_total") @db.Decimal(10, 2)
  createdAt         DateTime       @default(now()) @map("created_at")
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant           ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productVariantId])
  @@map("order_items")
}
