# --- Vercel (Next + /api) ---
# Supabase pooler: NO uses :5432 (session mode) en serverless — límite ~15 conexiones (EMAXCONNSESSION).
# Usá :6543 (transaction / PgBouncer) + pgbouncer + límite por instancia:
# DATABASE_URL=postgresql://...@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://user:pass@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
# Conexión directa al proyecto (migraciones / prisma migrate). En dashboard Supabase: "Direct connection".
DIRECT_DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Upstash Redis (TLS). Misma URL en: Vercel (dashboard), Railway workers y Railway WhatsApp (encola mensajes entrantes).
# Sin REDIS_URL en Railway, BullMQ intenta 127.0.0.1:6379 → ECONNREFUSED y no hay clasificación de leads ni pipeline.
# Solo la URL (rediss://...), NO el comando `redis-cli --tls -u ...` (si no, ENOENT / fallo raro de conexión).
# Ejemplo: rediss://default:TOKEN@REGION.upstash.io:6379
REDIS_URL=
AUTH_TOKEN_SECRET=
AUTH_TOKEN_TTL_SECONDS=28800
AUTH_PASSWORD_PEPPER=
AUTH_FALLBACK_EMAIL=
AUTH_FALLBACK_PASSWORD=
PUBLIC_API_BASE_URL=https://tu-app.vercel.app
# Opcional: si lo seteás, puede ser solo el origin (https://tu-app.vercel.app) o ya con /api.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_TENANT_ID=
# URL HTTPS de la app WhatsApp (Railway u otro)
WHATSAPP_SERVICE_URL=https://tu-wa.up.railway.app
# Baileys guarda credenciales en disco. En Railway: añadí un Volume con mount path /data (o el que elijas)
# y definí WA_AUTH_DIR dentro de ese mount, p. ej. WA_AUTH_DIR=/data/wa-auth. Sin volumen, cada deploy pide QR de nuevo.
# En local (sin RAILWAY_ENVIRONMENT) el default es ./wa-auth-data desde el cwd del proceso.
# WA_AUTH_DIR=/data/wa-auth
# Mercado Pago, etc. (ver tu .env.local de referencia)

# --- Railway — workers ---
# REDIS_URL (obligatoria), DATABASE_URL, OPENAI_API_KEY, LLM_*, SENDER_*, ORCHESTRATOR_*, PROCESSOR_*, …
# Misma URL pública que arriba: sin esto el sender no puede llamar al servicio WhatsApp (no existe el host "whatsapp" fuera de Docker Compose).
# WHATSAPP_SERVICE_URL=https://tu-wa.up.railway.app
#
# Comparación en shadow (solo si executionMode=shadow): POST JSON hacia waseller-crew (u otro).
# Opcionales en body: phone, correlationId, messageId, conversationId, recentMessages (ver CONTRATO_V1_1.md).
# Si definís LLM_SHADOW_COMPARE_SECRET (no vacío), workers envían Authorization: Bearer <secret> (alinear con SHADOW_COMPARE_SECRET en el crew).
# LLM_SHADOW_COMPARE_URL=
# LLM_SHADOW_COMPARE_TIMEOUT_MS=8000
# LLM_SHADOW_COMPARE_SECRET=

# --- Railway — WhatsApp ---
# REDIS_URL (obligatoria para encolar incoming), WA_AUTH_DIR + volumen, WHATSAPP_PORT=3100, WA_SESSION_SECRET, DATABASE_URL si aplica
