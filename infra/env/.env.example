# Copiá a .env.local o configurá en Vercel / Railway.

# Postgres (usá URL con pooler / PgBouncer en serverless — ver infra/deployment-strategy.md)
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# Opcional: Prisma Accelerate u otro proxy
# PRISMA_ACCELERATE_URL=

# Auth API (obligatorio en producción)
AUTH_TOKEN_SECRET=
AUTH_TOKEN_TTL_SECONDS=28800
AUTH_PASSWORD_PEPPER=
AUTH_FALLBACK_EMAIL=
AUTH_FALLBACK_PASSWORD=

# URL pública del API (webhooks Mercado Pago, OAuth). En Vercel suele ser https://TU_DOMINIO.vercel.app
PUBLIC_API_BASE_URL=https://

# Colas BullMQ (POST /api/messages/incoming y workers). En Vercel hace falta Redis accesible.
REDIS_URL=redis://127.0.0.1:6379
