# --- Vercel (Next + /api) ---
# Supabase: preferí URL del pooler (Transaction mode / port 6543 o host pooler.* según doc Supabase).
DATABASE_URL=postgresql://user:pass@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
# Upstash Redis (TLS). Ejemplo: rediss://default:TOKEN@REGION.upstash.io:6379
REDIS_URL=
AUTH_TOKEN_SECRET=
AUTH_TOKEN_TTL_SECONDS=28800
AUTH_PASSWORD_PEPPER=
AUTH_FALLBACK_EMAIL=
AUTH_FALLBACK_PASSWORD=
PUBLIC_API_BASE_URL=https://tu-app.vercel.app
# Opcional: si lo seteás, puede ser solo el origin (https://tu-app.vercel.app) o ya con /api.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_TENANT_ID=
# URL HTTPS de la app WhatsApp (Railway u otro)
WHATSAPP_SERVICE_URL=https://tu-wa.up.railway.app
# Mercado Pago, etc. (ver tu .env.local de referencia)

# --- Fly.io — workers ---
# DATABASE_URL, REDIS_URL, OPENAI_API_KEY, LLM_*, SENDER_*, ORCHESTRATOR_*, PROCESSOR_*, …

# --- Fly.io — WhatsApp ---
# WHATSAPP_PORT=3100, WA_AUTH_DIR, WA_SESSION_SECRET, REDIS_URL si aplica, DATABASE_URL si aplica
