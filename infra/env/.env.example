# --- Vercel (Next + /api) ---
# Supabase pooler: NO uses :5432 (session mode) en serverless — límite ~15 conexiones (EMAXCONNSESSION).
# Usá :6543 (transaction / PgBouncer) + pgbouncer + límite por instancia:
# DATABASE_URL=postgresql://...@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://user:pass@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
# Conexión directa al proyecto (migraciones / prisma migrate). En dashboard Supabase: "Direct connection".
DIRECT_DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Redis para BullMQ. Misma URL en: Railway workers y Railway WhatsApp (encola mensajes entrantes).
# Sin REDIS_URL en Railway, BullMQ intenta 127.0.0.1:6379 → ECONNREFUSED y no hay clasificación de leads ni pipeline.
# Solo la URL redis(s)://..., NO el comando `redis-cli --tls -u ...` (si no, ENOENT / fallo raro de conexión).
# Upstash (TLS): rediss://default:TOKEN@REGION.upstash.io:6379
# Redis en el mismo proyecto Railway: referenciá ${{Redis.REDIS_URL}} desde workers/WhatsApp (ver infra/railway-redis.md).
REDIS_URL=
AUTH_TOKEN_SECRET=
AUTH_TOKEN_TTL_SECONDS=28800
AUTH_PASSWORD_PEPPER=
AUTH_FALLBACK_EMAIL=
AUTH_FALLBACK_PASSWORD=
PUBLIC_API_BASE_URL=https://tu-app.vercel.app
# Origen público del catálogo (/tienda/<slug>). Sin barra final. Si no se define, workers usan PUBLIC_API_BASE_URL para armar links hacia waseller-crew (publicCatalogBaseUrl).
# PUBLIC_CATALOG_BASE_URL=https://tu-app.vercel.app
# Opcional: si lo seteás, puede ser solo el origin (https://tu-app.vercel.app) o ya con /api.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_TENANT_ID=
# URL HTTPS de la app WhatsApp (Railway u otro)
WHATSAPP_SERVICE_URL=https://tu-wa.up.railway.app
# Baileys guarda credenciales en disco. En Railway: añadí un Volume con mount path /data (o el que elijas)
# y definí WA_AUTH_DIR dentro de ese mount, p. ej. WA_AUTH_DIR=/data/wa-auth. Sin volumen, cada deploy pide QR de nuevo.
# En local (sin RAILWAY_ENVIRONMENT) el default es ./wa-auth-data desde el cwd del proceso.
# WA_AUTH_DIR=/data/wa-auth
# Mercado Pago, etc. (ver tu .env.local de referencia)

# --- Railway — workers ---
# REDIS_URL (obligatoria), DATABASE_URL, OPENAI_API_KEY, LLM_*, SENDER_*, ORCHESTRATOR_*, PROCESSOR_*, …
# Misma URL pública que arriba: sin esto el sender no puede llamar al servicio WhatsApp (no existe el host "whatsapp" fuera de Docker Compose).
# WHATSAPP_SERVICE_URL=https://tu-wa.up.railway.app
#
# Comparación en shadow (solo si executionMode=shadow): POST JSON hacia waseller-crew (u otro).
# URL típica crew (HTTPS, sin barra final en docs crew; el path es parte de la URL):
# LLM_SHADOW_COMPARE_URL=https://tu-dominio.railway.app/v1/shadow-compare
# Opcionales en body: phone, correlationId, messageId, conversationId, recentMessages, stockTable, inventoryNarrowingNote, tenantBrief (ver CONTRATO_V1_1.md).
# Shadow-compare: Bearer si hay secreto (mismo valor que SHADOW_COMPARE_SECRET en el crew).
# En workers podés usar LLM_SHADOW_COMPARE_SECRET o, si unificaste nombre en Railway, solo SHADOW_COMPARE_SECRET.
# LLM_SHADOW_COMPARE_TIMEOUT_MS=30000
# Con stockTable grande en crew, subir a 60000 o más (ver guía waseller-crew).
# LLM_SHADOW_COMPARE_STOCK_RAG_ROW_LIMIT=30
# LLM_SHADOW_COMPARE_SECRET=
# SHADOW_COMPARE_SECRET=
# Recorte de payload hacia el crew (tokens); ver CONTRATO_V1_1.md §2.
# LLM_SHADOW_COMPARE_MAX_INCOMING_CHARS=2500
# LLM_SHADOW_COMPARE_MAX_RECENT_MSG_CHARS=900
# LLM_SHADOW_COMPARE_MAX_REFERENCES=8
# LLM_SHADOW_COMPARE_MAX_DRAFT_CHARS=1400
# LLM_SHADOW_COMPARE_MAX_TENANT_COMMERCIAL_CONTEXT_CHARS=1400
# Raíz `memoryFacts` hacia crew: máx. líneas y caracteres por línea (default 40 × 400, alineado a ShadowCompareRequest en waseller-crew).
# LLM_SHADOW_COMPARE_MAX_MEMORY_FACT_LINES=40
# LLM_SHADOW_COMPARE_MAX_MEMORY_FACT_LINE_CHARS=400
# Telemetría JSON en stdout (nextAction/recommendedAction aplicados): handoff (default), all, 0=off
# WASELLER_LLM_ACTION_LOG=handoff
# Log JSON en stderr cuando el POST al crew no aplica (401, timeout, draft vacío, JSON inválido). Ver logs del servicio **workers**, no Redis.
# WASELLER_CREW_HTTP_LOG=true
# LLM_SHADOW_COMPARE_INCLUDE_STOCK_IMAGE_URL=false
# Snapshot `tenantRuntimeContext` hacia el crew (plan, políticas LLM, catálogo, integraciones sin secretos). Omitir: LLM_SHADOW_COMPARE_OMIT_TENANT_RUNTIME_CONTEXT=true
# Incluir número WhatsApp del canal del tenant (privacidad): LLM_SHADOW_COMPARE_INCLUDE_TENANT_WHATSAPP_NUMBER=true
# Obligatorio: con LLM_SHADOW_COMPARE_URL, forzar delegación NL al crew (ignora WASELLER_CREW_DELEGATE_CONVERSATION=false).
# Orquestador: stub + POST; sin intérprete OpenAI ni SelfHosted decide. Cobro/reserva/MP siguen en Waseller.
# WASELLER_CREW_MANDATORY=true
# Modo primary: una sola llamada al crew reemplaza la decisión interna (antes del verificador). Requiere LLM_SHADOW_COMPARE_URL + secret si el crew exige Bearer.
# WASELLER_CREW_PRIMARY=true
# Modo solo crew (orquestador + lead directo): POST al crew con baseline/interpretación stub; no OpenAI interpreter ni SelfHosted decide en orquestador.
# En lead worker (sin llmDecision del orquestador) el baseline del crew no usa el texto largo de plantillas. Si el crew no aplica → mensaje handoff.
# Requiere LLM_SHADOW_COMPARE_URL (no exige WASELLER_CREW_PRIMARY).
# WASELLER_CREW_SOLE_MODE=true
# Con primary + LLM habilitado: mandar también los turnos que antes iban solo al lead (variante resuelta) al orquestador primero
# (intérprete + RAG + verificador + crew). Cobro/reserva explícita sigue en lead si aplica forceLeadWorkerForReservedPaymentFollowUp.
# WASELLER_CREW_ORCHESTRATE_FIRST=true
# Con primary: relajar umbral de confianza para guardrails / requiresHuman (evita handoff por umbral del LLM interno).
# CREW_PRIMARY_RELAX_GUARDRAILS=true
# CREW_PRIMARY_GUARDRAIL_CONFIDENCE_FLOOR=0.55

# --- Railway — WhatsApp ---
# REDIS_URL (obligatoria para encolar incoming), WA_AUTH_DIR + volumen, WHATSAPP_PORT=3100, WA_SESSION_SECRET, DATABASE_URL si aplica
# En Railway: redacción de console de libs/Baileys (SessionEntry, buffers). Forzar redacción: WA_REDACT_CRYPTO_CONSOLE=1. Ver todo: WA_VERBOSE_LIBSIGNAL=1.
# LOG_LEVEL en Railway sin variable explícita suele defaultear a warn (menos ruido).

# --- Catálogo / imágenes ---
# Límite de imágenes guardadas por entidad. Se aplica en API para evitar payloads enormes (base64).
PRODUCT_MAX_IMAGE_UPLOADS=10
VARIANT_MAX_IMAGE_UPLOADS=6
# Límite por imagen (en caracteres del string URL o dataURL). Default recomendado: 220k (~165KB base64) para no romper requests.
PRODUCT_IMAGE_MAX_CHARS=220000
VARIANT_IMAGE_MAX_CHARS=220000

# --- Supabase Storage (uploads de imágenes desde el dashboard) ---
# OBLIGATORIO en Vercel. Sin esto /api/uploads/images devuelve 502 → los modales de stock no pueden subir
# y antes (en el código viejo) caían a un fallback que metía base64 en el body de POST /products → 413.
# La service role key se obtiene en Supabase → Project Settings → API → service_role.
# CRÍTICO: NUNCA exponer en variables NEXT_PUBLIC_*; este key bypasea RLS.
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Bucket público donde se guardan las imágenes (default product-images si no se setea).
SUPABASE_STORAGE_BUCKET=product-images

# --- Mercado Pago (OAuth + checkouts del storefront y conversacional) ---
# OBLIGATORIO en Vercel. Sin estos /tienda-config no puede conectar MP y los checkouts fallan.
# Crear app en https://www.mercadopago.com.ar/developers/panel/app y copiar credenciales.
MERCADO_PAGO_CLIENT_ID=
MERCADO_PAGO_CLIENT_SECRET=
# OAuth redirect: si se omite, se arma como `${PUBLIC_API_BASE_URL}/api/integrations/mercadopago/callback`.
# Debe coincidir EXACTAMENTE con la URI registrada en el panel de MP.
# MERCADO_PAGO_REDIRECT_URI=https://tu-app.vercel.app/api/integrations/mercadopago/callback
# Webhook secret (opcional pero MUY recomendado): si está, se valida firma HMAC de cada notificación.
# Generar en MP → Webhooks → "Mostrar la clave secreta".
MERCADO_PAGO_WEBHOOK_SECRET=
# Override del webhook URL si MP no debe pegar a PUBLIC_API_BASE_URL (raro). Default: ${PUBLIC_API_BASE_URL}/api/payments/mercadopago/webhook.
# Sin PUBLIC_API_BASE_URL ni MERCADO_PAGO_WEBHOOK_URL → MP NO recibe notification_url y los pagos NUNCA se confirman.
# MERCADO_PAGO_WEBHOOK_URL=
# Override del API base de MP. Default: https://api.mercadopago.com (no tocar salvo sandbox).
# MERCADO_PAGO_API_BASE_URL=
# Scope OAuth (default offline_access para refresh tokens).
# MERCADO_PAGO_OAUTH_SCOPE=offline_access

# --- Cifrado de tokens MP guardados en BD ---
# RECOMENDADO setear explícitamente. Si no se setea, cae a AUTH_TOKEN_SECRET → si rotás el JWT secret,
# perdés la posibilidad de descifrar los access tokens MP ya guardados (todos los tenants se desconectan).
# Generar con:  openssl rand -hex 32
PAYMENT_SECRET_KEY=
# Firma del state OAuth (CSRF). Mismo principio que arriba.
MERCADO_PAGO_STATE_SECRET=

# --- Storefront público (back_urls de MP) ---
# CRÍTICO para el checkout del carrito. Si se omite, el origen se infiere del header x-forwarded-host.
# En Vercel suele funcionar pero ante cualquier reverse proxy adicional o dominio custom rompe MP
# (auto_return exige back_urls.success HTTPS). Setearla explícitamente evita sorpresas.
# Sin barra final.
PUBLIC_STOREFRONT_BASE_URL=https://tu-app.vercel.app
